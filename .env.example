# Database — provide DATABASE_URL OR the separate DB_* params below (URL wins if set)
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=release_notifier
DB_SSLMODE=disable

# Redis — provide REDIS_URL OR the separate REDIS_* params below (URL wins if set)
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Server
PORT=8080
BASE_URL=http://localhost:8080

# GitHub API (optional, but 60 req/hr without token vs 5000 with)
GITHUB_TOKEN=

# SMTP
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USERNAME="your@email.com"
SMTP_PASSWORD="shhhhh"

# Scanner
SCAN_INTERVAL=10m
